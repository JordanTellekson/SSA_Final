{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "SSA_FinalContextConnection": "Server=(localdb)\\mssqllocaldb;Database=SSA-Final;Trusted_Connection=True;MultipleActiveResultSets=true"
  },
  "DomainAnalyzer": {
    "TimeoutSeconds": 5,
    "RdapTimeoutSeconds": 3,
    "RegistrationLookupCacheMinutes": 1440,
    "RdapBootstrapCacheHours": 24
  },
  "RiskThresholds": {
    "SuspiciousMinScore": 1,
    "BlocklistMatchScore": 100,
    "Typosquatting": {
      "EditDistanceOne": 20,
      "EditDistanceTwo": 14,
      "EditDistanceThree": 8
    },
    "Subdomains": {
      "TwoSubdomains": 6,
      "ThreeSubdomains": 10,
      "FourOrMoreSubdomains": 14
    },
    "HyphenAbuse": {
      "OneHyphen": 4,
      "TwoHyphens": 8,
      "ThreeHyphens": 12,
      "FourOrMoreHyphens": 16,
      "RepeatedHyphenBonus": 2,
      "MaxScore": 16
    },
    "ShannonEntropy": {
      "ModerateEntropy": 6,
      "HighEntropy": 12,
      "VeryHighEntropy": 16,
      "LongLabelBonus": 4,
      "MaxScore": 16
    },
    "RepeatedSegment": {
      "OneRepeatedSegment": 10,
      "MultipleRepeatedSegments": 14
    },
    "KeywordAbuse": {
      "RootLabelKeyword": 10,
      "SubdomainKeyword": 5,
      "MaxScore": 12
    },
    "DomainRegistrationAge": {
      "ThirtyDaysOrLess": 25,
      "NinetyDaysOrLess": 15
    },
    "DomainRegistrationLifespan": {
      "OneYearOrLess": 10,
      "TwoYearsOrLess": 5
    },
    "WhoisPrivacyProtection": {
      "PrivacyProtected": 5
    },
    "CharacterCompositionAnomaly": {
      "HighDigitRatio": 8,
      "ModerateDigitRatio": 5,
      "HighConsonantRatio": 5,
      "LongRepeatedRun": 5,
      "ModerateRepeatedRun": 3,
      "LongLabel": 4,
      "MaxScore": 12
    }
  },
  "ScanWorker": {
    "PerVariantDelayMs": 150,
    "MaxConcurrentScans": 3
  },
  "PhishingBlocklists": {
    "OpenPhish": {
      "Url": "https://openphish.com/feed.txt",
      "TimeoutSeconds": 30
    }
  },
  "CertStream": {
    "Enabled": true,
    "Url": "wss://certstream.calidog.io/",
    "DeduplicationWindowHours": 24,
    "StartupDelaySeconds": 15,
    "ReconnectDelaySeconds": 30,
    "MaxQueuedPerMinute": 60,
    "QueueOnlySuspiciousCandidates": true,
    "SuspiciousKeywords": [
      "login",
      "secure",
      "verify",
      "account",
      "signin",
      "auth",
      "sso",
      "password",
      "reset",
      "mfa",
      "support",
      "billing",
      "payment",
      "invoice",
      "wallet",
      "confirm",
      "update",
      "recovery",
      "admin",
      "portal",
      "webmail",
      "cloud",
      "download",
      "service"
    ]
  },
  "Reports": {
    "HighRiskLookbackHours": 24
  },
  "MonitoredBrands": {
    "Domains": [
      "paypal.com",
      "microsoft.com",
      "amazon.com"
    ],
    "ScanIntervalHours": 24,
    "StartupDelaySeconds": 30
  }
}
