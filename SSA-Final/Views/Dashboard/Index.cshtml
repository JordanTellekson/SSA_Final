@using SSA_Final.ViewModels
@model DomainScanViewModel

@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h1>Dashboard</h1>
<p class="text-muted">Enter a base domain to scan for typosquatting variants.</p>

@if (TempData["ScanError"] is string scanError)
{
    <div class="alert alert-danger" role="alert">@scanError</div>
}

@using (Html.BeginForm("Index", "Dashboard", FormMethod.Post))
{
    @Html.AntiForgeryToken()

    <div class="form-group mb-3">
        <label class="form-label">Base Domain</label>
        @Html.TextBoxFor(m => m.Domain, new
        {
            @class = "form-control",
            placeholder = "example.com"
        })
        @Html.ValidationMessageFor(m => m.Domain, "", new { @class = "text-danger" })
    </div>

    <button type="submit" class="btn btn-primary">Start Scan</button>
}

<hr />

<h2 class="h4">Recent Scans</h2>
@if (!Model.ScanHistory.Any())
{
    <p class="text-muted">No scans yet.</p>
}
else
{
    <ul class="list-group">
        @foreach (var scan in Model.ScanHistory)
        {
            <li class="list-group-item d-flex justify-content-between align-items-center">
                <div>
                    <strong>@scan.BaseDomain</strong>
                    <small class="text-muted ms-2">@scan.CreatedAt.ToLocalTime().ToString("g")</small>
                </div>
                <div class="d-flex gap-2 align-items-center">
                    <span class="badge @(scan.Status == SSA_Final.Models.DomainScanStatus.Failed ? "bg-danger" : "bg-primary")">@scan.Status</span>
                    <a asp-controller="ScanResults" asp-action="Details" asp-route-id="@scan.Id" class="btn btn-sm btn-outline-primary">View</a>
                </div>
            </li>
        }
    </ul>
}

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}