@using SSA_Final.ViewModels;
@model DomainScanViewModel

@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var scans = ViewBag.Scans as List<DomainScan>;
}

<h1>Dashboard</h1>

@if (ViewBag.Success != null)
{
    <div class="alert alert-success">
        @ViewBag.Success
    </div>
}

@using (Html.BeginForm("Index", "Dashboard", FormMethod.Post))
{
    @Html.AntiForgeryToken()

    <div class="form-group">
        <label>Base Domain</label>

        @Html.TextBoxFor(m => m.Domain, new
        {
            @class = "form-control",
            placeholder = "example.com"
        })

        @Html.ValidationMessageFor(m => m.Domain, "", new { @class = "text-danger" })
    </div>

    <br />

    <button type="submit" class="btn btn-primary">
        Start Scan
    </button>
}

<hr />

<h3>Previous Scans</h3>

@if (scans != null && scans.Any())
{
    <ul>
        @foreach (var scan in scans)
        {
            <li>
                <strong>@scan.Domain</strong> - @scan.CreatedAt
            </li>
        }
    </ul>
}
else
{
    <p>No scans yet.</p>
}

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}