<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SSA_Final</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/SSA_Final.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-dark bg-dark box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand fw-semibold" asp-area="" asp-controller="Home" asp-action="Index">SSA_Final</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Dashboard" asp-action="Index">Dashboard</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="ScanResults" asp-action="Index">Scan Results</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="History" asp-action="Index">History</a>
                        </li>
                    </ul>
                    <partial name="_LoginPartial" />
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="site-footer bg-dark text-white pt-5 pb-3">
        <div class="container">
            <div class="row gy-4 align-items-start">
                <div class="col-md-5 col-lg-4">
                    <h5 class="fw-bold mb-2">SSA_Final</h5>
                    <p class="text-white-50 small mb-0">
                        Domain risk assessment and typosquatting detection platform for security-conscious teams.
                    </p>
                </div>
                <div class="col-md-3 col-lg-2 offset-md-0 offset-lg-4">
                    <h6 class="text-uppercase text-white-50 fw-semibold small mb-3" style="letter-spacing: 0.08em;">Navigate</h6>
                    <ul class="list-unstyled mb-0 small">
                        <li class="mb-2"><a class="text-white-50 text-decoration-none footer-link" asp-area="" asp-controller="Home" asp-action="Index">Home</a></li>
                        <li class="mb-2"><a class="text-white-50 text-decoration-none footer-link" asp-area="" asp-controller="Dashboard" asp-action="Index">Dashboard</a></li>
                        <li class="mb-2"><a class="text-white-50 text-decoration-none footer-link" asp-area="" asp-controller="ScanResults" asp-action="Index">Scan Results</a></li>
                        <li><a class="text-white-50 text-decoration-none footer-link" asp-area="" asp-controller="History" asp-action="Index">History</a></li>
                    </ul>
                </div>
                <div class="col-md-2 col-lg-2">
                    <h6 class="text-uppercase text-white-50 fw-semibold small mb-3" style="letter-spacing: 0.08em;">Legal</h6>
                    <ul class="list-unstyled mb-0 small">
                        <li><a class="text-white-50 text-decoration-none footer-link" asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a></li>
                    </ul>
                </div>
            </div>
            <hr class="border-secondary mt-4 mb-3" />
            <p class="text-white-50 small mb-0">&copy; 2026 SSA_Final. All rights reserved.</p>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
