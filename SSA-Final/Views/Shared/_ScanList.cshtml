@using SSA_Final.ViewModels
@model ScanListViewModel

@if (Model.Mode == "history")
{
    <ul class="list-group">
        @foreach (var scan in Model.Scans)
        {
            string orbClass;
            string tooltip;
            switch (scan.Status)
            {
                case DomainScanStatus.Complete:
                    orbClass = "orb-success";
                    tooltip = "Scan complete — no threats found";
                    break;
                case DomainScanStatus.CompleteWithResults:
                    orbClass = "orb-warning";
                    tooltip = $"Scan complete — {scan.MaliciousCount} suspicious domain(s)";
                    break;
                default:
                    orbClass = "orb-pending";
                    tooltip = "Scan in progress";
                    break;
            }

            <li class="list-group-item d-flex align-items-center gap-3">
                <div class="orb @orbClass flex-shrink-0"
                     data-bs-toggle="tooltip"
                     data-bs-title="@tooltip"></div>

                <div class="flex-grow-1">
                    <strong>@scan.BaseDomain</strong>
                    <small class="text-muted ms-2">@scan.ScannedAt.ToLocalTime().ToString("g")</small>
                </div>

                <div class="d-flex gap-3 align-items-center">
                    @if (scan.MaliciousCount > 0)
                    {
                        <span class="badge bg-danger">@scan.MaliciousCount suspicious</span>
                    }
                    else if (scan.Status == DomainScanStatus.Complete)
                    {
                        <span class="badge bg-success">Clean</span>
                    }
                    <span class="text-muted small">@scan.Variants.Count variant(s)</span>
                    <a asp-controller="ScanResults" asp-action="Details" asp-route-id="@scan.Id"
                           class="btn btn-sm btn-outline-primary">
                        View Scan
                    </a>
                </div>
            </li>
        }
    </ul>
}
else
{
    <table class="table table-hover">
        <thead>
            <tr>
                <th>Base Domain</th>
                <th>Scanned At</th>
                <th>Variants</th>
                <th>Suspicious</th>
                <th>Status</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var scan in Model.Scans)
            {
                <tr>
                    <td><strong>@scan.BaseDomain</strong></td>
                    <td>@scan.ScannedAt.ToLocalTime().ToString("g")</td>
                    <td>@scan.Variants.Count</td>
                    <td>
                        @if (scan.MaliciousCount > 0)
                        {
                            <span class="badge bg-danger">@scan.MaliciousCount</span>
                        }
                        else
                        {
                            <span class="badge bg-success">0</span>
                        }
                    </td>
                    <td>@scan.Status</td>
                    <td>
                        <a asp-action="Details" asp-route-id="@scan.Id" class="btn btn-sm btn-outline-primary">View Details</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}