@model string?

<form id="searchForm"
      class="d-flex align-items-center"
      method="get"
      asp-controller="@ViewContext.RouteData.Values["controller"]"
      asp-action="@ViewContext.RouteData.Values["action"]">

    <input type="hidden" name="page" value="1" />

    @if (ViewContext.RouteData.Values["id"] != null)
    {
        <input type="hidden" name="id" value="@ViewContext.RouteData.Values["id"]" />
    }

    <div class="input-group">

        <input type="text"
               id="searchInput"
               name="query"
               value="@Model"
               class="form-control"
               placeholder="Search domains..."
               autocomplete="off" />

        <!-- Clears current search query -->
        <button id="clearSearchBtn" class="btn btn-outline-secondary">
            Clear Search
        </button>

        <!-- Clears both current search and applied filters -->
        <button type="button" id="resetBtn" class="btn btn-outline-danger">
            Reset All
        </button>
    </div>
</form>