@using SSA_Final.Models
@model ScanQuery

<button class="btn btn-outline-secondary" data-bs-toggle="modal" data-bs-target="#filterModal">
    Filters
</button>

<div class="modal fade" id="filterModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form id="filterForm">
                <div class="modal-header">
                    <h5 class="modal-title">Filters</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body">

                    <!-- Status Filter -->
                    <div class="mb-3">
                        <label>Status</label>
                        <select name="Status" class="form-select">
                            <option value="">All</option>
                            <option value="Pending" selected="@(Model.Status == DomainScanStatus.Pending)">Pending</option>
                            <option value="InProgress" selected="@(Model.Status == DomainScanStatus.InProgress)">In Progress</option>
                            <option value="Completed" selected="@(Model.Status == DomainScanStatus.Completed)">Completed</option>
                            <option value="Failed" selected="@(Model.Status == DomainScanStatus.Failed)">Failed</option>
                        </select>
                    </div>

                    <!-- Malicious Filter -->
                    <div class="mb-3">
                        <label>Threats</label>
                        <select name="HasMalicious" class="form-select">
                            <option value="">All</option>
                            <option value="true" selected="@(Model.HasMalicious == true)">Has Suspicious</option>
                            <option value="false" selected="@(Model.HasMalicious == false)">Clean Only</option>
                        </select>
                    </div>

                </div>

                <div class="modal-footer">
                    <button type="submit" class="btn btn-primary">Apply</button>
                    <a id="clearFiltersBtn" class="btn btn-secondary">Clear Filters</a>
                </div>
            </form>
        </div>
    </div>
</div>