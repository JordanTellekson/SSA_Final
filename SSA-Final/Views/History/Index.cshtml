@using SSA_Final.Models
@using SSA_Final.ViewModels
@using SSA_Final.Interfaces
@model PagedResultViewModel<DomainScan>

@{
    ViewData["Title"] = "History";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h1>Scan History</h1>

@if (!Model.Result.Items.Any())
{
    <p class="text-muted">No scans yet. <a asp-controller="Dashboard" asp-action="Index">Start a scan.</a></p>
}
else
{
    
    @await Html.PartialAsync("_SearchBar", Model.Query)
    @await Html.PartialAsync("_ScanList", new ScanListViewModel
    {
        Scans = Model.Result.Items,
        Mode = "history",
        Query = Model.Query
    })

    @await Html.PartialAsync("_Pagination", Model.Result)
}

@section Scripts {
    <script>
        const tooltipTriggerList = document.querySelectorAll('[data-bs-toggle="tooltip"]')
        const tooltipList = [...tooltipTriggerList].map(el => new bootstrap.Tooltip(el))
    </script>
}