@using SSA_Final.Models
@using SSA_Final.ViewModels
@using SSA_Final.Interfaces
@model PagedResultViewModel<DomainScan>

@{
    ViewData["Title"] = "History";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-header mb-4">
    <div class="d-flex align-items-start justify-content-between gap-3">
        <div>
            <h1 class="display-5">Scan History</h1>
            <p>A complete archive of all past scans, grouped by date.</p>
        </div>
        <a href="/api/Reports/download-csv"
           class="btn btn-outline-light btn-sm flex-shrink-0 mt-1"
           title="Download scan report as CSV (last 30 days)">
            ↓ Export Report
        </a>
    </div>
</div>

<div class="d-flex align-items-center gap-2 mb-3 flex-wrap">
    @await Html.PartialAsync("_Filters", Model.Filters)

    @await Html.PartialAsync("_SearchBar", Model.Query)
</div>

@if (!Model.HasAnyScans)
{
    <p class="text-muted">No scans yet. <a asp-controller="Dashboard" asp-action="Index">Start a scan.</a></p>
}
else
{
    <div id="resultsContainer">
        @await Html.PartialAsync("_ScanList", Model)
    </div>
}

@section Scripts {
    <script>
        const tooltipTriggerList = document.querySelectorAll('[data-bs-toggle="tooltip"]')
        const tooltipList = [...tooltipTriggerList].map(el => new bootstrap.Tooltip(el))
    </script>
    <script type="module" src="~/js/resultsViewControls.js"></script>
}