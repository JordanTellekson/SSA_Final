@using SSA_Final.Models
@model List<DomainScan>
@* History page: shows prior scans and their status summaries. *@

@{
    ViewData["Title"] = "History";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h1>Scan History</h1>

@if (!Model.Any())
{
    <p class="text-muted">No scans yet. <a asp-controller="Dashboard" asp-action="Index">Start a scan.</a></p>
}
else
{
    <ul class="list-group">
        @foreach (var scan in Model)
        {
            string orbClass;
            string tooltip;
            switch (scan.Status)
            {
                case DomainScanStatus.Complete:
                    orbClass = "orb-success";
                    tooltip = "Scan complete — no threats found";
                    break;
                case DomainScanStatus.CompleteWithResults:
                    orbClass = "orb-warning";
                    tooltip = $"Scan complete — {scan.NumMaliciousDomains} suspicious domain(s)";
                    break;
                default:
                    orbClass = "orb-pending";
                    tooltip = "Scan in progress";
                    break;
            }

            <li class="list-group-item d-flex align-items-center gap-3">
                <div class="orb @orbClass flex-shrink-0"
                     data-bs-toggle="tooltip"
                     data-bs-title="@tooltip"></div>

                <div class="flex-grow-1">
                    <strong>@scan.BaseDomain</strong>
                    <small class="text-muted ms-2">@scan.ScanDate.ToLocalTime().ToString("g")</small>
                </div>

                <div class="d-flex gap-3 align-items-center">
                    @if (scan.NumMaliciousDomains > 0)
                    {
                        <span class="badge bg-danger">@scan.NumMaliciousDomains suspicious</span>
                    }
                    else if (scan.Status == DomainScanStatus.Complete)
                    {
                        <span class="badge bg-success">Clean</span>
                    }
                    <span class="text-muted small">@scan.Results.Count variant(s)</span>
                    <a asp-controller="ScanResults" asp-action="Details" asp-route-id="@scan.Id"
                           class="btn btn-sm btn-outline-primary">
                        View Scan
                    </a>
                </div>
            </li>
        }
    </ul>
}

@section Scripts {
    <script>
        const tooltipTriggerList = document.querySelectorAll('[data-bs-toggle="tooltip"]')
        const tooltipList = [...tooltipTriggerList].map(el => new bootstrap.Tooltip(el))
    </script>
}
