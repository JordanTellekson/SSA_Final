@using SSA_Final.Models
@using SSA_Final.ViewModels
@using SSA_Final.Interfaces
@model PagedResultViewModel<DomainScan>

@{
    ViewData["Title"] = "Scan Results";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-header mb-4">
    <h1 class="display-5">Recent Scans</h1>
    <p>Your most recent domain scan activity, updated in real time.</p>
</div>

<div class="d-flex align-items-center gap-2 mb-3 flex-wrap">
    @await Html.PartialAsync("_Filters", Model.Filters)

    @await Html.PartialAsync("_SearchBar", Model.Query)
</div>

@if (!Model.HasAnyScans)
{
    <p class="text-muted">No scans yet. <a asp-controller="Dashboard" asp-action="Index">Start a scan.</a></p>
}
else
{
    <div id="resultsContainer">
        @await Html.PartialAsync("_ScanList", Model)
    </div>
}

@section Scripts {
    <script type="module" src="~/js/resultsViewControls.js"></script>
}