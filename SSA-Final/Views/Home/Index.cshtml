@{
    ViewData["Title"] = "Home Page";
}

<section class="d-flex align-items-center bg-dark bg-gradient text-white rounded-4 py-5 px-5 mb-5">
    <div class="col-lg-8 px-0">
        <h1 class="display-3 fw-bold mb-3">Secure smarter with every domain scan</h1>
        <p class="lead mb-3">
            Our platform helps teams quickly assess domain risk, track scan history, and surface actionable insights.
            Get a clear view of suspicious indicators so you can prioritize threats and protect your users with confidence.
        </p>
        <a class="btn btn-outline-light btn-lg mt-3" href="#features">Explore features ↓</a>
    </div>
</section>

<section id="features" class="py-5">
    <div class="text-center mb-5">
        <h2 class="display-6 fw-semibold">Platform features</h2>
        <p class="text-muted">Everything you need to investigate domains and monitor risk over time.</p>
    </div>

    <div class="row g-4">
        <div class="col-md-6 col-lg-4">
            <div class="card h-100 shadow-sm border-0">
                <div class="card-body p-4">
                    <span class="badge text-bg-primary rounded-pill mb-3">1</span>
                <h5 class="fw-semibold">Domain risk scoring</h5>
                <p class="text-muted mb-0">Generate weighted risk scores using configurable signals for fast triage decisions.</p>
                </div>
            </div>
        </div>
        <div class="col-md-6 col-lg-4">
            <div class="card h-100 shadow-sm border-0">
                <div class="card-body p-4">
                    <span class="badge text-bg-primary rounded-pill mb-3">2</span>
                <h5 class="fw-semibold">Threat signal analysis</h5>
                <p class="text-muted mb-0">Inspect detailed indicators to understand why a domain was flagged and what to investigate next.</p>
                </div>
            </div>
        </div>
        <div class="col-md-6 col-lg-4">
            <div class="card h-100 shadow-sm border-0">
                <div class="card-body p-4">
                    <span class="badge text-bg-primary rounded-pill mb-3">3</span>
                <h5 class="fw-semibold">Scan lifecycle tracking</h5>
                <p class="text-muted mb-0">Follow each scan from submission to completion with clear status visibility across the workflow.</p>
                </div>
            </div>
        </div>
        <div class="col-md-6 col-lg-4">
            <div class="card h-100 shadow-sm border-0">
                <div class="card-body p-4">
                    <span class="badge text-bg-primary rounded-pill mb-3">4</span>
                <h5 class="fw-semibold">Historical reporting</h5>
                <p class="text-muted mb-0">Review past scan outcomes and identify trends in domain behavior over time.</p>
                </div>
            </div>
        </div>
        <div class="col-md-6 col-lg-4">
            <div class="card h-100 shadow-sm border-0">
                <div class="card-body p-4">
                    <span class="badge text-bg-primary rounded-pill mb-3">5</span>
                <h5 class="fw-semibold">Action-ready results</h5>
                <p class="text-muted mb-0">See concise summaries with key findings so teams can respond quickly and consistently.</p>
                </div>
            </div>
        </div>
        <div class="col-md-6 col-lg-4">
            <div class="card h-100 shadow-sm border-0">
                <div class="card-body p-4">
                    <span class="badge text-bg-primary rounded-pill mb-3">6</span>
                <h5 class="fw-semibold">Operator-friendly dashboard</h5>
                <p class="text-muted mb-0">Use a clean interface built for security workflows, from quick scans to deeper review.</p>
                </div>
            </div>
        </div>
    </div>
</section>
